<div class="listen" data-controller="listen" data-listen-url-value="<%= @song ? url_for(@song.audio_file) : "" %>" data-listen-title-value="<%= @song&.title %>" data-listen-artist-value="<%= @song&.user&.username %>" data-listen-artwork-value="<%= @song&.artwork&.attached? ? url_for(@song.artwork) : "" %>">
  <% if !user_signed_in? %>
    <section class="guest">
      <div class="guest__card">
        <h1>Shuffle</h1>
        <p>Discover music anonymously. Listen once, rate once, move on.</p>

        <% if @song.present? %>
          <div class="guest__song">
            <div class="guest__artwork">
              <% if @song.artwork.attached? %>
                <%= image_tag @song.artwork, alt: "Artwork for #{@song.title}" %>
              <% else %>
                <div class="guest__placeholder">No artwork</div>
              <% end %>
              <button
                class="guest__overlay"
                type="button"
                data-action="player#playFromCard"
                data-player-url="<%= url_for(@song.audio_file) %>"
                data-player-title="<%= @song.title %>"
                data-player-artist="<%= @song.user.username %>"
                data-player-artwork="<%= @song.artwork.attached? ? url_for(@song.artwork) : "" %>"
                data-player-locked="true"
              >▶</button>
            </div>
            <div class="guest__meta">
              <strong><%= @song.title %></strong>
              <div><%= @song.user.username %></div>
            </div>
          </div>
        <% else %>
          <p>No songs available right now — upload one to get started</p>
        <% end %>

        <div class="guest__actions">
          <%= link_to "Sign in", new_user_session_path, class: "button" %>
          <%= link_to "Create account", new_user_registration_path, class: "button button--ghost" %>
        </div>
      </div>
    </section>
  <% elsif @song.present? %>
    <div class="listen__artwork">
      <% if @song.artwork.attached? %>
        <%= image_tag @song.artwork, alt: "Artwork for #{@song.title}", class: "listen__image" %>
      <% else %>
        <div class="listen__placeholder">No artwork</div>
      <% end %>
    </div>

    <div class="listen__meta">
      <h1><%= @song.title %></h1>
      <p>Uploaded by <strong><%= @song.user.username %></strong></p>
    </div>

    <div class="listen__player">
      <div class="listen__controls">
        <button class="button" type="button" data-action="listen#togglePlayback" data-listen-target="play">Play</button>
        <input class="listen__volume" type="range" min="0" max="1" step="0.01" value="1" data-action="input->listen#setVolume" data-listen-target="volume">
      </div>
    </div>

    <div class="listen__post hidden" data-listen-target="post">
      <div class="listen__post-actions">
        <button class="button" type="button" data-action="listen#showRating">Rating</button>
        <button class="button button--ghost" type="button" data-action="listen#showRating">Add to library?</button>
      </div>

      <div class="listen__rating hidden" data-listen-target="rating">
        <%= form_with url: ratings_path, scope: :rating do |form| %>
          <%= form.hidden_field :song_id, value: @song.id %>

          <fieldset class="rating" data-listen-target="stars">
            <legend>Rate this song</legend>
            <% 5.downto(1) do |star| %>
              <%= form.radio_button :stars, star, id: "rating_#{star}" %>
              <%= form.label :stars, "#{"★" * star}", for: "rating_#{star}" %>
            <% end %>
          </fieldset>

          <%= form.submit "Submit rating", data: { listen_target: "submit" } %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="listen__empty">
      <h1>No songs available right now — upload one to get started</h1>
      <%= link_to "Upload a song", new_song_path, class: "button" %>
    </div>
  <% end %>
</div>
