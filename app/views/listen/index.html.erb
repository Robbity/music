<div class="listen" data-controller="listen" data-listen-url-value="<%= @song ? url_for(@song.audio_file) : "" %>" data-listen-title-value="<%= @song&.title %>" data-listen-artist-value="<%= @song&.user&.username %>" data-listen-artwork-value="<%= @song&.artwork&.attached? ? url_for(@song.artwork) : "" %>" data-listen-id-value="<%= @song&.id %>">
  <% if !user_signed_in? %>
    <section class="guest">
      <div class="guest__card">
        <h1>Shuffle</h1>
        <p>Discover music anonymously. Listen once, rate once, move on.</p>

        <% if @song.present? %>
          <div class="guest__song">
            <div class="guest__artwork" style="background-color: <%= @song.artwork_color %>">
              <% if @song.artwork.attached? %>
                <%= image_tag @song.artwork, alt: "Artwork for #{@song.title}" %>
              <% else %>
                <div class="guest__placeholder"></div>
              <% end %>
              <button
                class="guest__overlay"
                type="button"
                data-action="player#playFromCard"
                data-player-url="<%= url_for(@song.audio_file) %>"
                data-player-title="<%= @song.title %>"
                data-player-artist="<%= @song.user.username %>"
                data-player-artwork="<%= @song.artwork.attached? ? url_for(@song.artwork) : "" %>"
                data-player-id="<%= @song.id %>"
                data-player-locked="true"
              >
                <span class="overlay__icon overlay__icon--play">▶</span>
                <span class="overlay__icon overlay__icon--pause">❚❚</span>
                <span class="overlay__bars">
                  <span></span>
                  <span></span>
                  <span></span>
                </span>
              </button>
            </div>
            <div class="guest__meta">
              <strong><%= @song.title %></strong>
              <div><%= @song.user.username %></div>
            </div>
          </div>
        <% else %>
          <p>No songs available right now — upload one to get started</p>
        <% end %>

        <div class="guest__actions">
          <%= link_to "Sign in", new_user_session_path, class: "button" %>
          <%= link_to "Create account", new_user_registration_path, class: "button button--ghost" %>
        </div>
      </div>
    </section>
  <% elsif @song.present? %>
    <div class="listen__card">
      <div class="listen__artwork" style="background-color: <%= @song.artwork_color %>">
        <% if @song.artwork.attached? %>
          <%= image_tag @song.artwork, alt: "Artwork for #{@song.title}", class: "listen__image" %>
        <% else %>
          <div class="listen__placeholder"></div>
        <% end %>
      </div>

      <div class="listen__meta">
        <h1><%= @song.title %></h1>
        <p>Uploaded by <strong><%= @song.user.username %></strong></p>
      </div>

      <div class="listen__player">
        <div class="listen__controls">
          <button class="button" type="button" data-action="listen#togglePlayback" data-listen-target="play">Play</button>
          <span class="listen__timer" data-listen-target="timer">0:00 / 0:00</span>
        </div>
      </div>

      <div id="listen-actions">
        <% if defined?(@prompt_rating) && @prompt_rating.present? %>
          <%= render "library_prompt", rating: @prompt_rating %>
        <% else %>
          <%= render "rating_form", song: @song, errors: nil %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="listen__empty">
      <h1>No songs available right now — upload one to get started</h1>
      <%= link_to "Upload a song", new_song_path, class: "button" %>
    </div>
  <% end %>
</div>
