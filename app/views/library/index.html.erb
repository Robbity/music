<div class="library__header">
  <h1>Library</h1>
  <form method="get" class="library__sort">
    <label for="library_sort">Sort by</label>
    <select id="library_sort" name="sort" onchange="this.form.submit()">
      <option value="date" <%= "selected" if params[:sort] == "date" || params[:sort].blank? %>>Date listened</option>
      <option value="rating" <%= "selected" if params[:sort] == "rating" %>>Rating</option>
    </select>
  </form>
</div>

<% if @ratings.any? %>
  <ul class="library">
    <% @ratings.each do |rating| %>
      <li class="library__item">
        <div class="library__artwork" style="background-color: <%= rating.song.artwork_color %>">
          <% if rating.song.artwork.attached? %>
            <%= image_tag rating.song.artwork, alt: "Artwork for #{rating.song.title}" %>
          <% else %>
            <div class="library__placeholder"></div>
          <% end %>
          <button class="library__overlay" type="button" data-action="player#playFromCard" data-player-url="<%= url_for(rating.song.audio_file) %>" data-player-title="<%= rating.song.title %>" data-player-artist="<%= rating.song.user.username %>" data-player-artwork="<%= rating.song.artwork.attached? ? url_for(rating.song.artwork) : "" %>">
            <span class="overlay__icon overlay__icon--play">▶</span>
            <span class="overlay__icon overlay__icon--pause">❚❚</span>
            <span class="overlay__bars">
              <span></span>
              <span></span>
              <span></span>
            </span>
          </button>
        </div>
        <div class="library__info">
          <div class="library__title"><%= rating.song.title %></div>
          <div class="library__artist">by <%= rating.song.user.username %></div>
          <div class="library__rating">
            <span class="library__metric">Rating: <%= "★" * rating.stars %><%= "☆" * (5 - rating.stars) %></span>
            <span class="library__date"><%= rating.created_at.strftime("%b %d, %Y") %></span>
          </div>
        </div>
        <div class="library__actions">
          <details>
            <summary>•••</summary>
            <div class="menu">
              <%= link_to "Download", rails_blob_path(rating.song.audio_file, disposition: "attachment"), class: "menu__item" %>
              <%= button_to "Remove", rating_path(rating), method: :delete, class: "menu__item", data: { turbo_confirm: "Remove this song from your library?" } %>
            </div>
          </details>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>You have not rated any songs yet.</p>
<% end %>
