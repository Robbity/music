<div class="library__header">
  <h1>Uploads</h1>
  <form method="get" class="library__sort">
    <label for="upload_sort" class="library__sort-label">Sort by</label>
    <select id="upload_sort" name="sort" class="library__sort-select" onchange="this.form.submit()">
      <option value="recent" <%= "selected" if params[:sort] == "recent" || params[:sort].blank? %>>Newest</option>
      <option value="plays" <%= "selected" if params[:sort] == "plays" %>>Plays</option>
      <option value="rating" <%= "selected" if params[:sort] == "rating" %>>Average rating</option>
    </select>
  </form>
</div>

<% if @songs.any? %>
  <ul class="library">
    <% @songs.each do |song| %>
      <% average = song.ratings.average(:stars) %>
      <% rating_count = song.ratings.size %>
      <li class="library__item">
        <div class="library__artwork" style="background-color: <%= song.artwork_color %>">
          <% if song.artwork.attached? %>
            <%= image_tag song.artwork, alt: "Artwork for #{song.title}" %>
          <% else %>
            <div class="library__placeholder"></div>
          <% end %>
          <button class="library__overlay" type="button" data-action="player#playFromCard" data-player-url="<%= url_for(song.audio_file) %>" data-player-title="<%= song.title %>" data-player-artist="<%= song.user.username %>" data-player-artwork="<%= song.artwork.attached? ? url_for(song.artwork) : "" %>" data-player-id="<%= song.id %>">
            <span class="overlay__icon overlay__icon--play">▶</span>
            <span class="overlay__icon overlay__icon--pause">❚❚</span>
            <span class="overlay__bars">
              <span></span>
              <span></span>
              <span></span>
            </span>
          </button>
        </div>
        <div class="library__info">
          <div class="library__title"><%= song.title %></div>
          <div class="library__artist">by <%= song.user.username %></div>
          <div class="library__meta">
            <span class="library__metric"><span class="library__label">Plays</span> <%= song.plays_count || 0 %></span>
            <span class="library__metric">
              <% if average.present? %>
                <span class="library__label">Average rating</span> <%= average.round(1) %> / 5
              <% else %>
                <span class="library__label">Average rating</span> No ratings yet
              <% end %>
            </span>
            <span class="library__metric"><span class="library__label">Ratings</span> <%= rating_count %></span>
          </div>
        </div>
        <div class="library__actions">
          <details>
            <summary>•••</summary>
            <div class="menu">
              <%= button_to "Delete", song_path(song), method: :delete, class: "menu__item", data: { turbo_confirm: "Delete this song?" } %>
            </div>
          </details>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No songs yet.</p>
<% end %>

<div class="library__footer">
  <%= link_to "+ Add track", new_song_path, class: "button" %>
</div>
