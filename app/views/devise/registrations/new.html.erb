<section class="auth">
  <%= link_to "Shuffle", root_path, class: "auth__logo" %>
  <div class="auth__card">
    <%= link_to "← Back", root_path, class: "auth__back" %>
    <h1>Create account</h1>

    <% if resource.errors.any? %>
      <ul class="auth__errors" role="alert">
        <% resource.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    <% end %>

    <%= form_with model: resource, as: resource_name, url: registration_path(resource_name) do |form| %>
      <div class="auth__field">
        <%= form.label :username, "Username" %>
        <%= form.text_field :username, required: true, autofocus: true, autocomplete: "username" %>
      </div>

      <div class="auth__field">
        <%= form.label :email, "Email" %>
        <%= form.email_field :email, required: true, autocomplete: "email" %>
      </div>

      <div class="auth__field">
        <%= form.label :password, "Password" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password" %>
      </div>

      <div class="auth__field">
        <%= form.label :password_confirmation, "Confirm password" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
      </div>

      <%= form.submit "Create account", class: "button" %>
    <% end %>

    <p>
      Already have an account?
      <%= link_to "Sign in", new_user_session_path %>
    </p>
  </div>
</section>
