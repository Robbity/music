<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>MusicApp</title>
    <style>
      :root {
        color-scheme: light;
      }

      body {
        margin: 0;
        font-family: "Georgia", "Times New Roman", serif;
        background: linear-gradient(135deg, #f7f2e7, #efe1d6);
        color: #2b211c;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .card {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid #e4d3c6;
        border-radius: 16px;
        padding: 32px 36px;
        box-shadow: 0 12px 30px rgba(59, 42, 33, 0.18);
        text-align: center;
        max-width: 520px;
        margin: 24px;
      }

      h1 {
        margin: 0 0 12px;
        font-size: 32px;
        letter-spacing: 0.5px;
      }

      p {
        margin: 0;
        font-size: 16px;
        line-height: 1.6;
      }

      .pill {
        display: inline-block;
        margin-top: 18px;
        padding: 6px 12px;
        border-radius: 999px;
        background: #2b211c;
        color: #f7f2e7;
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>MusicApp is running</h1>
      <p>Your Rails app is healthy and responding on the root path.</p>
      <span class="pill">OK</span>
    </div>
  </body>
</html>
